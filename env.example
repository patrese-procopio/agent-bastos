# ─────────────────────────────────────────────────────────────────────────────
# AGENT BASTOS — Variáveis de Ambiente
#
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha com suas chaves reais
# 3. NUNCA commite o .env — ele está no .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Principal (Groq) ──────────────────────────────────────────────────────
# Obter em: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Visão Computacional (Anthropic Claude) ────────────────────────────────────
# Obter em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Visão Computacional (Google Gemini) ───────────────────────────────────────
# Obter em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Drive OAuth2 ───────────────────────────────────────────────────────
# Baixar em: Google Cloud Console → APIs → Credenciais → OAuth 2.0
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Baixar em: Firebase Console → Configurações → Contas de serviço
FIREBASE_KEY_PATH=serviceAccountKey.json

# ── Criptografia de Logs (Fernet) ─────────────────────────────────────────────
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here

# ── (Opcional) Transcrição Desktop ───────────────────────────────────────────
# PASTA_AUDIOS=C:\caminho\para\audios
