# Agent Bastos — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas chaves reais
# NUNCA commite o .env — ele está no .gitignore

# ─── LLM — Groq API ───────────────────────────────────────────────────────────
# Obtenha em: https://console.groq.com
GROQ_API_KEY=sua_chave_groq_aqui

# ─── Visão Computacional — Google Gemini ──────────────────────────────────────
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui

# ─── Google Drive (opcional — necessário para o Drive Indexer) ────────────────
# Coloque o credentials.json na raiz do projeto
GOOGLE_CREDENTIALS_PATH=credentials.json

# ─── Telegram OSINT (Telethon) ────────────────────────────────────────────────
# 1) Gere api_id e api_hash em: https://my.telegram.org → "API development tools"
# 2) Rode uma única vez: .venv\Scripts\python.exe scripts\telegram_login.py
#    (ele pede telefone + código e imprime a TELEGRAM_SESSION pra colar aqui)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=

# ─── Configurações do sistema ─────────────────────────────────────────────────
CHROMA_DIR=data/chroma_db
DOUTRINA_DIR=data/doutrina
LOG_PATH=logs/missao.log
# ─── JWT — Autenticação ───────────────────────────────────────────────────────
# Gere uma chave forte com: python -c "import secrets; print(secrets.token_hex(48))"
# NUNCA use a chave padrão em produção — gere sempre uma nova.
JWT_SECRET_KEY=gere_uma_chave_forte_com_o_comando_acima

# ─── Fernet — Criptografia de logs ───────────────────────────────────────────
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=gere_com_o_comando_acima

# ─── Senhas de usuários (bcrypt hash) ────────────────────────────────────────
# Gere com: python scripts/setar_senha.py <usuario>
ADMIN_PASSWORD_HASH=
ANALISTA_PASSWORD_HASH=

# ─── Human-in-the-Loop (WhatsApp via n8n + Evolution API) ────────────────────
# URL do webhook n8n que recebe os alertas de risco alto
# Copie do painel do n8n após importar o workflow human_loop_whatsapp.json
N8N_WEBHOOK_HITL=http://localhost:5678/webhook/hitl-bastos

# Chave secreta para o callback do n8n → backend (gere qualquer string forte)
# python -c "import secrets; print(secrets.token_hex(24))"
HITL_CALLBACK_KEY=gere_uma_chave_forte_aqui

# URL pública ou local do backend (usada para montar o callback_url enviado ao n8n)
BASTOS_CALLBACK_URL=http://127.0.0.1:8000

# Timeout em minutos para expirar aprovações sem resposta (padrão: 60)
HITL_TIMEOUT_MINUTOS=60

# Números WhatsApp autorizados a receber alertas HITL e responder CONFIRMAR/REJEITAR
# Formato: 55DDD9XXXXXXXX separados por vírgula, sem espaços. Suporta até 15 números.
# Qualquer um da lista pode responder — o primeiro a confirmar/rejeitar encerra a votação.
# Exemplo: WA_NUMEROS_HITL=5592999990000,5592888880000,5592777770000
WA_NUMEROS_HITL=55DDDXXXXXXXXX

# Evolution API
EVOLUTION_API_KEY=sua_chave_evolution_aqui
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_INSTANCE=bastos