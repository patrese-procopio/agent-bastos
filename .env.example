# Agent Bastos — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas chaves reais
# NUNCA commite o .env — ele está no .gitignore

# ─── LLM — Groq API ───────────────────────────────────────────────────────────
# Obtenha em: https://console.groq.com
GROQ_API_KEY=sua_chave_groq_aqui

# ─── Visão Computacional — Google Gemini ──────────────────────────────────────
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui

# ─── Google Drive (opcional — necessário para o Drive Indexer) ────────────────
# Coloque o credentials.json na raiz do projeto
GOOGLE_CREDENTIALS_PATH=credentials.json

# ─── Telegram OSINT (Telethon) ────────────────────────────────────────────────
# 1) Gere api_id e api_hash em: https://my.telegram.org → "API development tools"
# 2) Rode uma única vez: .venv\Scripts\python.exe scripts\telegram_login.py
#    (ele pede telefone + código e imprime a TELEGRAM_SESSION pra colar aqui)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=

# ─── Configurações do sistema ─────────────────────────────────────────────────
CHROMA_DIR=data/chroma_db
DOUTRINA_DIR=data/doutrina
LOG_PATH=logs/missao.log
# ___ JWT - acesso security ____#
JWT_SECRET_KEY=efd498c71d17cdf76bbb1eef2768220a37d7bbf90f2859e07fe4bcece22ca056