# Agent Bastos — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas chaves reais
# NUNCA commite o .env — ele está no .gitignore

# LLM — Groq API (https://console.groq.com)
GROQ_API_KEY=sua_chave_groq_aqui

# Google Drive (opcional — necessário para o Drive Indexer)
# Coloque o credentials.json na raiz do projeto
GOOGLE_CREDENTIALS_PATH=credentials.json

# Configurações do sistema
CHROMA_DIR=data/chroma_db
DOUTRINA_DIR=data/doutrina
LOG_PATH=logs/missao.log
